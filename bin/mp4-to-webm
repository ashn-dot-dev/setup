#!/bin/sh
set -eux

FILE="${1}"
WEBM="${FILE%.mp4}.webm"

# Encoding strategy taken from https://trac.ffmpeg.org/wiki/Encode/VP9#twopass
ffmpeg -i "${FILE}" -c:v libvpx-vp9 -b:v 0 -crf 30 -pass 1 -an -f null /dev/null
ffmpeg -i "${FILE}" -c:v libvpx-vp9 -b:v 0 -crf 30 -pass 2 -c:a libopus "${WEBM}"
rm ffmpeg*.log
